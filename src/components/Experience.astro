---
import { experiences } from '../data/experience';
---

<section id="experience" class="py-16 max-w-7xl mx-auto px-4 sm:px-6">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-10">
    <div>
      <p class="section-label mb-3">// EXPERIENCE</p>
      <h2 class="text-3xl md:text-4xl font-bold text-[#FAFAFA] mb-3">Where I've built things</h2>
      <p class="text-[#71717A] max-w-2xl">3 years across DevOps, teaching, and platform engineering.</p>
    </div>

    <div class="experience-count">
      <span>{experiences.length}</span>
      <small>Roles</small>
    </div>
  </div>

  <div class="experience-list">
    {experiences.map(exp => (
      <article class="experience-card">
        <div class="experience-main">
          <div class="experience-marker"></div>
          <div class="min-w-0">
            <div class="experience-heading">
              <div>
                <h3>{exp.role}</h3>
                <p>{exp.company}</p>
              </div>
              <span>{exp.period}</span>
            </div>

            <div class="experience-meta">
              <span>{exp.location}</span>
            </div>

            <p class="experience-summary">{exp.summary}</p>
          </div>
        </div>

        <div class="experience-side">
          <div class="tech-row">
            {exp.tech.slice(0, 7).map(t => (
              <span>{t}</span>
            ))}
            {exp.tech.length > 7 && (
              <span>+{exp.tech.length - 7} more</span>
            )}
          </div>

          <details>
            <summary>
              Key achievements
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </summary>
            <ul>
              {exp.achievements.map(a => (
                <li>{a}</li>
              ))}
            </ul>
          </details>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3B82F6;
  }

  .experience-count {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    width: fit-content;
    padding: 0.7rem 0.85rem;
    border: 1px solid #27272A;
    border-radius: 8px;
    background: #111111;
  }

  .experience-count span {
    color: #FAFAFA;
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1;
  }

  .experience-count small {
    color: #71717A;
    font-size: 0.75rem;
  }

  .experience-list {
    display: grid;
    gap: 1rem;
  }

  .experience-card {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.8fr);
    gap: 1.25rem;
    padding: 1.25rem;
    border: 1px solid #27272A;
    border-radius: 8px;
    background:
      linear-gradient(90deg, rgba(59, 130, 246, 0.08), rgba(17, 17, 17, 0) 38%),
      #111111;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .experience-card:hover {
    transform: translateY(-2px);
    border-color: #3F3F46;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
  }

  .experience-main {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
  }

  .experience-marker {
    width: 0.7rem;
    height: 0.7rem;
    margin-top: 0.45rem;
    border-radius: 9999px;
    background: #3B82F6;
    box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.13);
  }

  .experience-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .experience-heading h3 {
    color: #FAFAFA;
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .experience-heading p {
    margin-top: 0.25rem;
    color: #3B82F6;
    font-size: 0.9rem;
    font-weight: 650;
  }

  .experience-heading span {
    flex: 0 0 auto;
    padding: 0.35rem 0.55rem;
    border: 1px solid #27272A;
    border-radius: 9999px;
    background: rgba(10, 10, 10, 0.48);
    color: #A1A1AA;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    line-height: 1;
  }

  .experience-meta {
    margin-top: 0.65rem;
    color: #71717A;
    font-size: 0.8rem;
  }

  .experience-summary {
    max-width: 48rem;
    margin-top: 0.8rem;
    color: #A1A1AA;
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .experience-side {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    min-width: 0;
  }

  .tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tech-row span {
    padding: 0.28rem 0.55rem;
    border: 1px solid #27272A;
    border-radius: 7px;
    background: rgba(10, 10, 10, 0.52);
    color: #A1A1AA;
    font-size: 0.75rem;
    font-weight: 550;
    line-height: 1.2;
  }

  details {
    border-top: 1px solid #27272A;
    padding-top: 0.85rem;
  }

  summary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #3B82F6;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 700;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary svg {
    transform: rotate(90deg);
  }

  summary svg {
    transition: transform 0.2s ease;
  }

  details ul {
    display: grid;
    gap: 0.45rem;
    margin-top: 0.75rem;
  }

  details li {
    color: #A1A1AA;
    font-size: 0.8rem;
    line-height: 1.55;
  }

  details li::before {
    content: "";
    display: inline-block;
    width: 0.38rem;
    height: 0.38rem;
    margin-right: 0.5rem;
    border-radius: 9999px;
    background: #3B82F6;
    vertical-align: 0.08rem;
  }

  @media (max-width: 900px) {
    .experience-card {
      grid-template-columns: 1fr;
    }

    .experience-heading {
      flex-direction: column;
      gap: 0.7rem;
    }
  }
</style>
