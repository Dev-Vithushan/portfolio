---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section id="projects" class="py-16 bg-[#0A0A0A]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <p class="section-label mb-3">// FEATURED WORK</p>
    <h2 class="text-3xl md:text-4xl font-bold text-[#FAFAFA] mb-3">Projects I've shipped</h2>
    <p class="text-[#71717A] mb-8">Click any project for the full case study.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.filter(p => p.featured).map(project => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3B82F6;
  }
</style>
