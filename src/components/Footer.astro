---
import { siteConfig } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[#27272A] bg-[#0A0A0A] mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="footer-grid">
      <div class="footer-column footer-brand">
        <p class="footer-title font-mono font-bold text-[#FAFAFA]"><span class="text-[#3B82F6]">~/</span>vithushan</p>
        <p class="text-sm text-[#71717A] leading-relaxed max-w-sm">{siteConfig.tagline}</p>
        <div class="footer-meta">
          <p>{siteConfig.location}</p>
          <p class="text-[#3B82F6]">{siteConfig.availability}</p>
        </div>
      </div>

      <div class="footer-column md:mx-auto">
        <p class="footer-title text-xs font-mono text-[#71717A] uppercase tracking-widest">Navigation</p>
        <ul class="footer-links">
          {['about', 'tech', 'experience', 'projects', 'writing', 'contact'].map(link => (
            <li><a href={`${base}/#${link}`} class="footer-link capitalize">{link}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-column md:ml-auto">
        <p class="footer-title text-xs font-mono text-[#71717A] uppercase tracking-widest">Find me</p>
        <div class="footer-socials">
          <a href={siteConfig.social.github} target="_blank" rel="noopener" class="footer-social-link">
            <svg class="footer-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="footer-social-link">
            <svg class="footer-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href={siteConfig.social.email} class="footer-social-link">
            <svg class="footer-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Email
          </a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {currentYear} Logeswaran Vithushan. All rights reserved.</p>
      <a href={`${base}/#hero`}>Back to top</a>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(10rem, 0.7fr) minmax(12rem, 0.85fr);
    gap: 3rem;
    align-items: start;
    margin-bottom: 2rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .footer-title {
    min-height: 1.25rem;
    margin-bottom: 1rem;
    line-height: 1.25;
  }

  .footer-meta {
    display: grid;
    gap: 0.25rem;
    margin-top: 1rem;
    color: #71717A;
    font-size: 0.75rem;
    line-height: 1.5;
  }

  .footer-links,
  .footer-socials {
    display: grid;
    gap: 0.65rem;
  }

  .footer-link,
  .footer-social-link {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    color: #A1A1AA;
    font-size: 0.875rem;
    line-height: 1.4;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer-link:hover,
  .footer-social-link:hover {
    color: #FAFAFA;
    transform: translateX(2px);
  }

  .footer-social-link {
    gap: 0.625rem;
  }

  .footer-icon {
    width: 1rem;
    height: 1rem;
    flex: 0 0 1rem;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid #27272A;
    color: #71717A;
    font-size: 0.75rem;
  }

  .footer-bottom a {
    color: #A1A1AA;
    transition: color 0.2s ease;
  }

  .footer-bottom a:hover {
    color: #3B82F6;
  }

  :global(html:not(.dark)) .footer-title {
    color: #0F172A;
  }

  :global(html:not(.dark)) .footer-meta,
  :global(html:not(.dark)) .footer-bottom {
    color: #64748B;
  }

  :global(html:not(.dark)) .footer-link,
  :global(html:not(.dark)) .footer-social-link,
  :global(html:not(.dark)) .footer-bottom a {
    color: #475569;
  }

  :global(html:not(.dark)) .footer-link:hover,
  :global(html:not(.dark)) .footer-social-link:hover {
    color: #0F172A;
  }

  :global(html:not(.dark)) .footer-bottom {
    border-color: #D8E0EA;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-column {
      margin-left: 0;
      margin-right: 0;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
