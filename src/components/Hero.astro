---
import { siteConfig } from '../data/site';


const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const profileImage = `${base}/profile.png`;
const resumeHref = `${base}/cv.pdf`;
const roles = ['DevOps Engineer', 'Site Reliability Engineer', 'Cloud Engineer'];
const techBadges = ['Kubernetes', 'Grafana', 'Pyroscope', 'AWS', 'Backstage', 'FluxCD', 'Terraform'];
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Grid background -->
  <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>
  <!-- Radial gradient mask -->
  <div class="absolute inset-0 bg-gradient-radial pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center pt-24 pb-16">
    <!-- Profile photo -->
    <div class="profile-frame mx-auto mb-6 animate-fade-in">
      <img
        src={profileImage}
        alt={`${siteConfig.name} profile photo`}
        width="184"
        height="184"
        class="profile-photo"
        loading="eager"
        decoding="async"
      />
    </div>

    <!-- Availability pill -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[#27272A] bg-[#111111] text-sm text-[#A1A1AA] mb-8 animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      Available for remote roles
    </div>

    <!-- Name -->
    <h1 class="hero-name mb-5 animate-slide-up" aria-label={siteConfig.name}>
      <span class="name-kicker">Hello, I'm</span>
      <span class="name-line">{siteConfig.name.split(' ')[0]}</span>
      <span class="name-line name-accent">{siteConfig.name.split(' ')[1]}</span>
    </h1>

    <!-- Animated role title -->
    <div class="h-8 mb-6">
      <p id="role-title" class="text-lg md:text-xl font-mono text-[#3B82F6]"></p>
    </div>

    <!-- Description -->
    <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
      {siteConfig.tagline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
      <a href="#projects" class="btn-primary text-base px-6 py-3">
        View Projects
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="#contact" class="btn-secondary text-base px-6 py-3">Get in Touch</a>
      <a href={resumeHref} download class="flex items-center gap-2 text-sm text-[#71717A] hover:text-[#A1A1AA] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download CV
      </a>
    </div>

    <!-- Tech badges -->
    <div class="flex flex-wrap justify-center gap-2 mb-16">
      {techBadges.map((badge, i) => (
        <span
          class="px-3 py-1 text-xs font-mono rounded-full border border-[#27272A] text-[#71717A] bg-[#111111] hover:border-[#3B82F6] hover:text-[#3B82F6] transition-all cursor-default"
          style={`animation-delay: ${i * 0.1}s`}
        >
          {badge}
        </span>
      ))}
    </div>

    <!-- Scroll indicator -->
    <div class="flex flex-col items-center gap-2 text-[#71717A] animate-bounce-slow">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(59, 130, 246, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .bg-gradient-radial {
    background: radial-gradient(ellipse at center, transparent 30%, #0A0A0A 80%);
  }

  .text-gradient {
    background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-name {
    display: grid;
    justify-items: center;
    gap: 0.1rem;
    color: #FAFAFA;
    font-family: 'Space Grotesk', 'Manrope', system-ui, sans-serif;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .name-kicker {
    display: inline-flex;
    margin-bottom: 0.75rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(59, 130, 246, 0.24);
    border-radius: 9999px;
    background: rgba(59, 130, 246, 0.08);
    color: #93C5FD;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .name-line {
    display: block;
    font-size: clamp(3.3rem, 9vw, 7.8rem);
    font-weight: 700;
  }

  .name-accent {
    position: relative;
    padding: 0 0.2rem 0.12rem;
    background: linear-gradient(135deg, #60A5FA 0%, #22D3EE 48%, #A78BFA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .name-accent::after {
    content: "";
    position: absolute;
    left: 8%;
    right: 8%;
    bottom: 0;
    height: 0.45rem;
    border-radius: 9999px;
    background: linear-gradient(90deg, rgba(59, 130, 246, 0), rgba(59, 130, 246, 0.65), rgba(34, 211, 238, 0));
    opacity: 0.78;
  }

  .profile-frame {
    width: clamp(8.5rem, 16vw, 11.5rem);
    aspect-ratio: 1;
    border-radius: 9999px;
    padding: 4px;
    background:
      linear-gradient(#0A0A0A, #0A0A0A) padding-box,
      linear-gradient(135deg, rgba(59, 130, 246, 0.9), rgba(20, 184, 166, 0.72), rgba(139, 92, 246, 0.85)) border-box;
    border: 1px solid transparent;
    box-shadow:
      0 0 0 1px rgba(250, 250, 250, 0.06),
      0 20px 60px rgba(59, 130, 246, 0.18);
  }

  .profile-photo {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 9999px;
    object-fit: cover;
    background: #111111;
  }

  .btn-primary {
    background: #3B82F6;
    color: white;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-primary:hover {
    background: #2563EB;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.4);
  }

  .btn-secondary {
    background: transparent;
    color: #FAFAFA;
    border-radius: 8px;
    border: 1px solid #3F3F46;
    font-weight: 500;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-secondary:hover {
    border-color: #3B82F6;
    color: #3B82F6;
  }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 0.6s ease-out both; }
  .animate-slide-up { animation: slideUp 0.6s ease-out 0.2s both; }
  .animate-bounce-slow { animation: bounce 2s infinite; }
</style>

<script define:vars={{ roles }}>
  const el = document.getElementById('role-title');
  if (!el) return;

  let roleIdx = 0;
  let charIdx = 0;
  let deleting = false;
  let pauseCounter = 0;

  function tick() {
    const current = roles[roleIdx];
    if (!deleting) {
      el.textContent = current.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        deleting = true;
        pauseCounter = 30;
        setTimeout(tick, 1500);
        return;
      }
    } else {
      if (pauseCounter > 0) { pauseCounter--; }
      else {
        el.textContent = current.slice(0, charIdx - 1);
        charIdx--;
        if (charIdx === 0) {
          deleting = false;
          roleIdx = (roleIdx + 1) % roles.length;
        }
      }
    }
    setTimeout(tick, deleting ? 40 : 70);
  }

  setTimeout(tick, 800);
</script>
