---
import type { Project } from '../types/index';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const statusColors: Record<string, string> = {
  'In Production': 'text-green-400 bg-green-400/10 border-green-400/20',
  'Completed': 'text-blue-400 bg-blue-400/10 border-blue-400/20',
  'In Progress': 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20',
};
---

<a
  href={`${base}/projects/${project.slug}`}
  class="group block rounded-xl border border-[#27272A] bg-[#111111] overflow-hidden hover:border-[#3B82F6]/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#3B82F6]/10"
>
  <!-- Thumbnail placeholder -->
  <div class="relative aspect-video bg-gradient-to-br from-[#1A1A1A] to-[#0A0A0A] flex items-center justify-center overflow-hidden">
    <div class="text-[#27272A] text-6xl font-bold font-mono opacity-30">
      {project.title.charAt(0)}
    </div>
    <!-- Status badge -->
    <div class={`absolute top-3 right-3 px-2.5 py-1 rounded-full text-xs font-medium border ${statusColors[project.status]}`}>
      {project.status}
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="font-bold text-[#FAFAFA] text-lg mb-2 group-hover:text-[#3B82F6] transition-colors">
      {project.title}
    </h3>
    <p class="text-[#71717A] text-sm mb-3 italic">{project.tagline}</p>
    <p class="text-[#A1A1AA] text-sm leading-relaxed mb-4 line-clamp-3">{project.description}</p>

    <!-- Metrics -->
    <div class="grid grid-cols-2 gap-2 mb-4">
      {Object.entries(project.metrics).slice(0, 4).map(([key, val]) => (
        <div class="text-center p-2 rounded-lg bg-[#1A1A1A]">
          <p class="text-sm font-bold text-[#3B82F6]">{val}</p>
          <p class="text-xs text-[#71717A] mt-0.5">{key}</p>
        </div>
      ))}
    </div>

    <!-- Tech pills -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {project.tech.slice(0, 5).map(t => (
        <span class="px-2 py-0.5 text-xs rounded-md border border-[#27272A] text-[#71717A]">{t}</span>
      ))}
      {project.tech.length > 5 && (
        <span class="px-2 py-0.5 text-xs text-[#71717A]">+{project.tech.length - 5}</span>
      )}
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-1 text-sm text-[#3B82F6] group-hover:gap-2 transition-all">
      Read case study
      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
