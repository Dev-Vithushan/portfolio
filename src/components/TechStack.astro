---
import { techStack, techCategories } from '../data/techStack';

const categoryMeta: Record<string, { label: string; accent: string; soft: string }> = {
  'Cloud Platforms': { label: 'Cloud', accent: '#38BDF8', soft: 'rgba(56, 189, 248, 0.12)' },
  'Containers & Orchestration': { label: 'Runtime', accent: '#60A5FA', soft: 'rgba(96, 165, 250, 0.12)' },
  'CI/CD & IaC': { label: 'Delivery', accent: '#A78BFA', soft: 'rgba(167, 139, 250, 0.12)' },
  'Observability': { label: 'Telemetry', accent: '#34D399', soft: 'rgba(52, 211, 153, 0.12)' },
  'Platform Engineering': { label: 'Platform', accent: '#F59E0B', soft: 'rgba(245, 158, 11, 0.12)' },
  'Scripting & OS': { label: 'Systems', accent: '#F472B6', soft: 'rgba(244, 114, 182, 0.12)' },
  'AI Tooling': { label: 'AI', accent: '#22D3EE', soft: 'rgba(34, 211, 238, 0.12)' },
};
---

<section id="tech" class="py-24 bg-[#0A0A0A]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <p class="section-label mb-3">// TECH STACK</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#FAFAFA] mb-3">Tools I work with daily</h2>
        <p class="text-[#71717A] max-w-2xl">Built things in production with each of these.</p>
      </div>

      <div class="flex gap-3">
        <div class="metric-block">
          <span class="metric-value">{techStack.length}</span>
          <span class="metric-label">Tools</span>
        </div>
        <div class="metric-block">
          <span class="metric-value">{techCategories.length}</span>
          <span class="metric-label">Areas</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
      {techCategories.map(cat => {
        const tools = techStack.filter(t => t.category === cat.name);
        const meta = categoryMeta[cat.name];
        return (
          <div class="tech-panel" style={`--accent: ${meta.accent}; --accent-soft: ${meta.soft};`}>
            <div class="panel-header">
              <div>
                <span class="panel-kicker">{meta.label}</span>
                <h3>{cat.name}</h3>
              </div>
              <span class="tool-count">{tools.length}</span>
            </div>

            <div class="tool-list">
              {tools.map(tool => (
                <span class="tool-chip">
                  <span class="tool-dot"></span>
                  {tool.name}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3B82F6;
  }

  .metric-block {
    min-width: 5.5rem;
    padding: 0.875rem 1rem;
    border: 1px solid #27272A;
    border-radius: 8px;
    background: #111111;
  }

  .metric-value,
  .metric-label {
    display: block;
  }

  .metric-value {
    color: #FAFAFA;
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1;
  }

  .metric-label {
    margin-top: 0.35rem;
    color: #71717A;
    font-size: 0.75rem;
  }

  .tech-panel {
    min-height: 13rem;
    padding: 1.25rem;
    border: 1px solid #27272A;
    border-radius: 8px;
    background:
      linear-gradient(180deg, var(--accent-soft), rgba(17, 17, 17, 0) 42%),
      #111111;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .tech-panel:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 54%, #27272A);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
  }

  .panel-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #27272A;
  }

  .panel-kicker {
    display: inline-flex;
    margin-bottom: 0.4rem;
    color: var(--accent);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .panel-header h3 {
    color: #FAFAFA;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .tool-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex: 0 0 auto;
    border: 1px solid color-mix(in srgb, var(--accent) 42%, #27272A);
    border-radius: 9999px;
    background: var(--accent-soft);
    color: #FAFAFA;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .tool-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2rem;
    padding: 0.35rem 0.65rem;
    border: 1px solid #27272A;
    border-radius: 7px;
    background: rgba(10, 10, 10, 0.58);
    color: #A1A1AA;
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.2;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .tool-chip:hover {
    border-color: color-mix(in srgb, var(--accent) 46%, #27272A);
    background: rgba(250, 250, 250, 0.03);
    color: #FAFAFA;
  }

  .tool-dot {
    width: 0.42rem;
    height: 0.42rem;
    flex: 0 0 auto;
    border-radius: 9999px;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
</style>
