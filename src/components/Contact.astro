---
import { siteConfig } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resumeHref = `${base}/cv.pdf`;
---

<section id="contact" class="py-24 bg-[#0A0A0A]">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <p class="section-label mb-3">// LET'S TALK</p>
    <h2 class="text-3xl md:text-4xl font-bold text-[#FAFAFA] mb-4">
      Open to remote DevOps & Platform roles
    </h2>
    <p class="text-[#71717A] mb-12">
      Based in Sri Lanka. Available for remote globally with US/EU overlap.
    </p>

    <!-- Contact methods -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
      <!-- Email -->
      <div class="p-5 rounded-xl border border-[#27272A] bg-[#111111] hover:border-[#3B82F6]/50 transition-all group">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-[#3B82F6]/10 border border-[#3B82F6]/20 mb-3 mx-auto">
          <svg class="w-5 h-5 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <p class="text-xs text-[#71717A] mb-1">Email</p>
        <a href={`mailto:${siteConfig.email}`} class="text-sm text-[#FAFAFA] hover:text-[#3B82F6] transition-colors break-all">
          {siteConfig.email}
        </a>
        <button
          class="copy-btn mt-2 block mx-auto text-xs text-[#71717A] hover:text-[#3B82F6] transition-colors"
          data-copy={siteConfig.email}
        >
          Copy address
        </button>
      </div>

      <!-- LinkedIn -->
      <div class="p-5 rounded-xl border border-[#27272A] bg-[#111111] hover:border-[#3B82F6]/50 transition-all">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-[#3B82F6]/10 border border-[#3B82F6]/20 mb-3 mx-auto">
          <svg class="w-5 h-5 text-[#3B82F6]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <p class="text-xs text-[#71717A] mb-1">LinkedIn</p>
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="text-sm text-[#FAFAFA] hover:text-[#3B82F6] transition-colors">
          Direct message
        </a>
      </div>

      <!-- CV -->
      <div class="p-5 rounded-xl border border-[#27272A] bg-[#111111] hover:border-[#3B82F6]/50 transition-all">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-[#3B82F6]/10 border border-[#3B82F6]/20 mb-3 mx-auto">
          <svg class="w-5 h-5 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <p class="text-xs text-[#71717A] mb-1">Resume</p>
        <a href={resumeHref} download class="text-sm text-[#FAFAFA] hover:text-[#3B82F6] transition-colors">
          Download CV
        </a>
      </div>
    </div>

    <!-- Social icons -->
    <div class="flex items-center justify-center gap-4 mb-12">
      <a href={siteConfig.social.github} target="_blank" rel="noopener" class="p-3 rounded-lg border border-[#27272A] text-[#71717A] hover:text-[#FAFAFA] hover:border-[#3F3F46] transition-all">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="p-3 rounded-lg border border-[#27272A] text-[#71717A] hover:text-[#FAFAFA] hover:border-[#3F3F46] transition-all">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href={siteConfig.social.email} class="p-3 rounded-lg border border-[#27272A] text-[#71717A] hover:text-[#FAFAFA] hover:border-[#3F3F46] transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
    </div>

    <!-- Terminal CTA -->
    <div class="inline-block rounded-xl border border-[#27272A] bg-[#111111] overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-2 border-b border-[#27272A] bg-[#1A1A1A]">
        <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-[#FFBD2E]"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
      </div>
      <div class="px-6 py-4 font-mono text-sm">
        <span class="text-[#3B82F6]">$ </span>
        <span id="hire-cmd" class="text-[#FAFAFA]"></span>
        <span class="animate-pulse text-[#3B82F6]">▋</span>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3B82F6;
  }
</style>

<script>
  // Copy email button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy address'; }, 2000);
    });
  });

  // Terminal typewriter
  const cmdEl = document.getElementById('hire-cmd');
  if (cmdEl) {
    const cmd = 'hire vithushan --role=devops-engineer --devops-engineer=true';
    let i = 0;
    const type = () => {
      if (i < cmd.length) {
        cmdEl.textContent = cmd.slice(0, i + 1);
        i++;
        setTimeout(type, 60);
      }
    };
    setTimeout(type, 500);
  }
</script>
